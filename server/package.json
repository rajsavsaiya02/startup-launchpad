{
  "name": "startup-launchpad-server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for the Startup LaunchPad application.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "db:init": "node src/scripts/db/migrations/initDb.js",
    "db:seed": "node src/scripts/db/migrations/defaultDb.js",
    "db:setup": "node src/scripts/db/migrations/initDb.js && node src/scripts/db/migrations/defaultDb.js",
    "seed:users": "node src/scripts/db/seeders/01_UserProfiles_PublicProfile_Seed.js",
    "seed:reset": "node src/scripts/db/seeders/00_Reset_Dummy_Data.js",
    "test:db-connection": "node ../Tests/Database/db_connection_test.js",
    "test:db-crud": "node ../Tests/Database/db_crud_test.js",
    "test:email": "node ../Tests/Backend/email_test.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "check-disk-space": "^3.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "pg": "^8.16.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
